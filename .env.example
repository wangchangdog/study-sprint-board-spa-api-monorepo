# ===========================================
# Study Sprint Board — 環境変数テンプレート
# ===========================================
# このファイルを .env にコピーして値を設定してください
# cp .env.example .env

# PostgreSQL（docker-compose.yml と一致させること）
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/study_sprint_board?schema=public"

# アプリ URL
APP_WEB_URL="http://localhost:4173"
APP_API_URL="http://localhost:4010"

# API サーバー
API_PORT="4010"
SESSION_SECRET="change-me-for-development"
SESSION_COOKIE_NAME="study_sprint_board_session"

# Vite SPA
VITE_ENABLE_API="true"
VITE_API_BASE_URL="http://localhost:4010"
